  
<main class="admin-main">
    <section class="admin-section form-section">
        <h2 class="section-title">Adicionar Novo Produto</h2>
        
        {{>mensagens}}

        <form action="/cadastrar" method="POST" enctype="multipart/form-data" class="product-form">
            <div class="input-group">
                <label for="nome">Nome da Peça</label>
                <input type="text" id="nome" name="nome" placeholder="Ex: Camiseta Básica">
            </div>
            
            <div class="input-group">
                <label for="valor">Preço (R$)</label>
                <input type="number" id="valor" name="valor" placeholder="0.00" step="0.01">
            </div>
            
            <select name="categoria" class="select-categoria">
                <option value="">Categoria do Produto</option>
                <option value="alimenticio">Alimentício</option>
                <option value="eletronico">Eletrônico</option>
                <option value="vestuario">Vestuário</option>
            </select>

            <div class="input-group">
                <label for="imagem">Foto da Peça</label>
                <input type="file" id="imagem" name="imagem" accept="image/*">
            </div>
            
            <button type="submit" class="btn-submit">Cadastrar</button>
        </form>
    </section>

    <hr class="divider">
    {{lista}}
</main>